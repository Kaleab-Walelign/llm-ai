GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
GEOSERVER_URL=https://nrms.ati.gov.et/geoserver

# Local rangeland_data root (contains *_timeseries dirs + woreda_shp_file/)
NRMS_DATA_DIR=/data/rangeland
NRMS_TIFS_HOST_PATH=/home/kaleabwalelign/Documents/rangeland_data

# Dockerized services (defaults work with docker compose)
DATABASE_URL=postgresql://nrms:nrms@localhost:5432/nrms
REDIS_URL=redis://localhost:6379/0

# Shapefile attribute for woreda names (auto-detected if empty)
WOREDA_NAME_FIELD=

CORS_ORIGINS=https://nrms.ati.gov.et,http://nrms.ati.gov.et
